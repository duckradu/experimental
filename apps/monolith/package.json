{
  "name": "@experimental/monolith",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "build-and-migrate": "pnpm build && pnpm db:migrate",
    "build-and-prepare-temp": "pnpm build && pnpm db:migrate && pnpm db:seed",
    "start": "vinxi start",
    "version": "vinxi version",
    "db:check": "drizzle-kit check --config=src/config/db.ts",
    "db:generate": "drizzle-kit generate --config=src/config/db.ts",
    "db:generate:schema-barrel": "node --import tsx --env-file .env ./scripts/generate-db-schema-barrel.ts",
    "db:migrate": "node --import tsx --env-file .env ./src/lib/db/migrate.ts",
    "db:push": "drizzle-kit push --config=src/config/db.ts",
    "db:seed": "node --import tsx --env-file .env ./src/lib/db/seed.ts",
    "db:drop": "drizzle-kit drop --config=src/config/db.ts",
    "db:studio": "drizzle-kit studio --config=src/config/db.ts"
  },
  "dependencies": {
    "@modular-forms/solid": "^0.21.0",
    "@solid-primitives/context": "^0.2.3",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.13.3",
    "@solidjs/start": "^1.0.1",
    "@unocss/reset": "^0.60.3",
    "@zag-js/avatar": "^0.57.0",
    "@zag-js/menu": "^0.57.0",
    "@zag-js/solid": "^0.57.0",
    "argon2": "^0.40.3",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "dotenv-expand": "^11.0.6",
    "drizzle-orm": "^0.31.2",
    "nanoid": "^5.0.7",
    "postgres": "^3.4.4",
    "solid-js": "^1.8.17",
    "tailwind-variants": "^0.2.1",
    "valibot": "^0.31.1",
    "vinxi": "^0.3.11"
  },
  "devDependencies": {
    "@iconify-json/solar": "^1.1.9",
    "@iconify/json": "^2.2.215",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "drizzle-kit": "^0.22.7",
    "glob": "^10.4.1",
    "solid-devtools": "^0.30.1",
    "tsx": "^4.15.4",
    "unocss": "^0.60.3",
    "unocss-preset-animations": "^1.0.2",
    "unplugin-icons": "^0.19.0"
  },
  "author": "radu.dascalu@pm.me"
}
